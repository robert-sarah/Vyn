// GUI example — real tkinter runtime
import std.gui;
use std.io.println;

fn on_click() -> void {
    gui.alert("Welcome to Vyn GUI!");
}

fn main() -> i32 {
    gui.window("Vyn App", 480, 320);
    gui.label("lbl1", "Hello Vyn GUI!", 80, 60);
    gui.label("lbl2", "Click the button below", 60, 100);
    gui.button("btn1", "Click", 160, 160, "on_click");
    io.println("Launching GUI...");
    gui.run();
    return 0;
}
